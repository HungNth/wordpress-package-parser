{
    "name": "hungnth/wordpress-package-parser",
    "description": "A PHP package for parsing WordPress plugin, theme, and generic package metadata.",
    "type": "library",
    "keywords": [
        "wordpress",
        "package",
        "parser"
    ],
    "authors": [
        {
            "name": "HungNth",
            "email": "thienhungdev@gmail.com"
        }
    ],
    "homepage": "https://github.com/HungNth/wordpress-package-parser",
    "support": {
        "issues": "https://github.com/HungNth/wordpress-package-parser/issues",
        "source": "https://github.com/HungNth/wordpress-package-parser"
    },
    "require": {
        "php": ">=7.4",
        "erusev/parsedown": "^1.8"
    },
    "require-dev": {
        "ext-zip": "*",
        "phpunit/phpunit": "^9.6"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "WpPackageParser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpPackageParser\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
